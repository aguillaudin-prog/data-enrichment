# Template for Streamlit Cloud Secrets — paste this content into the
# Streamlit Cloud "Settings → Secrets" UI for the deployed app, after
# filling in the password hashes (generated via `python -m app.generate_auth_hash`).
#
# Locally, copy this file to `.streamlit/secrets.toml` (gitignored) and
# fill it in to test the auth flow before deploying.

[cookie]
name = "dic_auth"
# 32+ random bytes hex. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
key = "PASTE_RANDOM_HEX_HERE"
expiry_days = "7"

[users.arnaud]
email = "arnaud@example.org"
name = "Arnaud"
password_hash = "$2b$12$PASTE_BCRYPT_HASH_HERE"

[users.collegue1]
email = "c1@example.org"
name = "Collègue 1"
password_hash = "$2b$12$PASTE_BCRYPT_HASH_HERE"

[users.collegue2]
email = "c2@example.org"
name = "Collègue 2"
password_hash = "$2b$12$PASTE_BCRYPT_HASH_HERE"

[users.collegue3]
email = "c3@example.org"
name = "Collègue 3"
password_hash = "$2b$12$PASTE_BCRYPT_HASH_HERE"

[users.collegue4]
email = "c4@example.org"
name = "Collègue 4"
password_hash = "$2b$12$PASTE_BCRYPT_HASH_HERE"

[users.collegue5]
email = "c5@example.org"
name = "Collègue 5"
password_hash = "$2b$12$PASTE_BCRYPT_HASH_HERE"


# Autorouter.aero API credentials — for the 🌐 'Suggestion approfondie'
# button in the leg editor and the sidebar diagnostic. Get the OAuth 2.0
# client_id and client_secret by signing in at https://autorouter.aero
# and creating an API client. Leave the section out if you don't have
# credentials yet — the local A* suggester keeps working.
[autorouter]
base_url = "https://api.autorouter.aero/v1.0"
token_url = "https://api.autorouter.aero/oauth2/token"
client_id = "PASTE_AUTOROUTER_CLIENT_ID"
client_secret = "PASTE_AUTOROUTER_CLIENT_SECRET"
