# Template for Streamlit Cloud Secrets — paste this content into the
# Streamlit Cloud "Settings → Secrets" UI for the deployed app.
#
# L'auth utilisateur est gérée par Streamlit Community Cloud directement
# (Settings → Sharing → "Only specific people" + allowlist d'emails Google).
# Aucun mot de passe à stocker ici. Seules les credentials API tierces
# vivent dans les secrets.

# Autorouter.aero API credentials — OAuth 2.0 client_credentials flow.
# client_id is the email used to log into autorouter.aero, client_secret
# is the password. The account must have API access enabled (request via
# autorouter support ticket if not already done). Leave the section out
# if you don't have credentials — the local A* suggester keeps working.
[autorouter]
base_url = "https://api.autorouter.aero/v1.0"
token_url = "https://api.autorouter.aero/v1.0/oauth2/token"
client_id = "ton.email@example.org"
client_secret = "ton-mot-de-passe-autorouter"
