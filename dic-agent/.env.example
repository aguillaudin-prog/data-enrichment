# Configuration locale — ne JAMAIS committer ce fichier rempli.
# Copie ce fichier en .env et remplis avec tes vraies valeurs.

# OpenAIP API (espaces aériens, zones P/R/D, FIR, CTR, TMA)
# Crée un compte sur https://www.openaip.net puis Profile → Clients.
OPENAIP_API_KEY=

# Optionnel : pour l'extraction LLM des DIC passées (parsing libre des Word).
ANTHROPIC_API_KEY=
